---
export interface FaqItem {
  question: string;
  answer: string;
}

export interface Props {
  title: string;
  items: FaqItem[];
}

const { title, items } = Astro.props;

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<section id="faq" class="bg-white dark:bg-darkblue px-4 py-[10vh] flex justify-center">
  <div class="flex flex-col gap-y-10 w-full max-w-3xl">
    <h2 class="text-blue dark:text-white font-bold text-4xl lg:text-5xl text-center">
      {title}
    </h2>
    <div class="flex flex-col gap-y-6">
      {items.map((item) => (
        <div class="rounded-lg border border-slate-200 dark:border-white/10 p-5">
          <h3 class="text-emerald-700 dark:text-green font-semibold text-xl">
            {item.question}
          </h3>
          <p class="text-blue dark:text-white text-lg pt-2">{item.answer}</p>
        </div>
      ))}
    </div>
  </div>
</section>
<script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
