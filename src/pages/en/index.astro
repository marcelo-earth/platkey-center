---
import { changeLanguage } from 'i18next';
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/home/HeroSection';
import LandingSection from '../../components/home/LandingSection';
import FaqSection from '../../components/home/FaqSection.astro';
import Footer from '../../components/Footer';

changeLanguage('en');

const faqItems = [
  {
    question: 'What is PlatKey?',
    answer:
      'PlatKey is an open-source browser extension that adds keyboard shortcuts, an augmented search bar, an SSH mode, and other productivity tools to your Platzi experience.',
  },
  {
    question: 'Is PlatKey free?',
    answer: 'Yes, PlatKey is completely free and open source.',
  },
  {
    question: 'Which browsers does PlatKey support?',
    answer: 'PlatKey works on Google Chrome, Microsoft Edge, Brave, and Safari.',
  },
  {
    question: 'Does PlatKey collect my personal data?',
    answer:
      'No. PlatKey does not collect any personal information, as detailed in its privacy policy.',
  },
  {
    question: 'Is PlatKey an official Platzi product?',
    answer:
      'No, PlatKey is an independent open-source community project and is not officially affiliated with Platzi.',
  },
  {
    question: 'How do I install PlatKey?',
    answer:
      'Click the Install button at the top of this page and follow the instructions for your browser.',
  },
];
---

<Layout
  title="PlatKey - Browser Extension for Platzi | Keyboard Shortcuts and Productivity Tools"
  description="PlatKey is a powerful browser extension that enhances your Platzi learning experience with keyboard shortcuts, interactive features, and productivity tools for better online education."
  keywords="PlatKey, Platzi, browser extension, Chrome extension, Safari extension, keyboard shortcuts, online learning, education tools, productivity, study tools"
  canonical="https://platkey.astronware.com/en"
  alternateUrls={[
    { hreflang: 'es', href: 'https://platkey.astronware.com' },
    { hreflang: 'en', href: 'https://platkey.astronware.com/en' },
    { hreflang: 'x-default', href: 'https://platkey.astronware.com' }
  ]}
>
  <main>
    <HeroSection client:visible lang="en" />
    <LandingSection client:visible lang="en" />
    <FaqSection title="Frequently asked questions" items={faqItems} />
    <Footer lang="en" />
  </main>
</Layout>
