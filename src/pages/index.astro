---
import { changeLanguage } from 'i18next';
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/home/HeroSection';
import LandingSection from '../components/home/LandingSection';
import FaqSection from '../components/home/FaqSection.astro';
import Footer from '../components/Footer';
import '@fontsource-variable/ibm-plex-sans';

changeLanguage('es');

const faqItems = [
  {
    question: '¿Qué es PlatKey?',
    answer:
      'PlatKey es una extensión de navegador de código abierto que añade atajos de teclado, un buscador aumentado, un modo SSH y otras herramientas de productividad a tu experiencia en Platzi.',
  },
  {
    question: '¿PlatKey es gratis?',
    answer: 'Sí, PlatKey es completamente gratuito y de código abierto.',
  },
  {
    question: '¿En qué navegadores funciona PlatKey?',
    answer: 'PlatKey funciona en Google Chrome, Microsoft Edge, Brave y Safari.',
  },
  {
    question: '¿PlatKey recopila mis datos personales?',
    answer:
      'No. PlatKey no recopila ninguna información personal, tal como se detalla en su política de privacidad.',
  },
  {
    question: '¿PlatKey es un producto oficial de Platzi?',
    answer:
      'No, PlatKey es un proyecto independiente de código abierto creado por la comunidad y no está afiliado oficialmente a Platzi.',
  },
  {
    question: '¿Cómo instalo PlatKey?',
    answer:
      'Haz clic en el botón Instalar en la parte superior de esta página y sigue las instrucciones para tu navegador.',
  },
];
---

<Layout
  title="PlatKey - Extensión de Navegador para Platzi | Atajos de Teclado y Herramientas de Productividad"
  description="PlatKey es una extensión de navegador que mejora tu experiencia de aprendizaje en Platzi con atajos de teclado, funciones interactivas y herramientas de productividad para una mejor educación online."
  keywords="PlatKey, Platzi, extensión de navegador, extensión Chrome, extensión Safari, atajos de teclado, aprendizaje online, herramientas educativas, productividad, herramientas de estudio"
  canonical="https://platkey.astronware.com"
  alternateUrls={[
    { hreflang: 'es', href: 'https://platkey.astronware.com' },
    { hreflang: 'en', href: 'https://platkey.astronware.com/en' },
    { hreflang: 'x-default', href: 'https://platkey.astronware.com' }
  ]}
>
  <main>
    <HeroSection client:visible lang="es" />
    <LandingSection client:visible lang="es" />
    <FaqSection title="Preguntas frecuentes" items={faqItems} />
    <Footer lang="es" />
  </main>
</Layout>
